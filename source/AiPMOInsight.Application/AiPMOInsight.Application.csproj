<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>14</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.4" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.4" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AiPMOInsight.Domain\AiPMOInsight.Domain.csproj" />
  </ItemGroup>

  <!-- LLM agent prompts: embedded so the registry can version them by content hash at runtime. -->
  <ItemGroup>
    <EmbeddedResource Include="Features\Analysis\Prompts\*.prompt.md" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="AiPMOInsight.Application.Tests" />
  </ItemGroup>

</Project>
